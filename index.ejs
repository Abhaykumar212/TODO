<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TODO APP</title>
    <link rel="shortcut icon" type="x-icon" href="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcSyvT_KWjUBGL5xMaNmtr_xU-smdIFTywLpRg&s">
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body>
    <div class="min-h-screen bg-zinc-900 p-5 text-white">
        <h1 class="text-center font-bold text-2xl mb-2">TODO APP</h1>
        <form action="/create" method="post">
            <div class="flex-col justify-item-center ml-5 mr-5 ">
                <input type="text" name="title" id="" placeholder="Enter your task"
                    class="rounded-md block bg-green-900 px-5 py-2 w-full outline-none">
                <textarea name="description" id="" placeholder="Enter description of your task..."
                    class="rounded-md block bg-blue-900 px-5 py-2 w-full resize-none mt-5 outline-none"></textarea>
                <button type="submit" class="text-white bg-pink-800 rounded-md px-5 py-2 mt-5 active:scale-95">Create
                    Task</button>
            </div>
        </form>

        <div class="forms flex gap-4 flex-wrap mt-11 ml-5">
            <% if(files.length > 0) { %>
              <% files.forEach((val) => { %>
                <div class="form bg-zinc-800 w-72 rounded-md mt-11 shadow-lg hover:bg-zinc-700 transition-colors duration-300 p-4">
                  <h1 class="text-white font-semibold text-lg mb-2 truncate"><%= val.substring(0,val.length-4) %></h1>
                  <div class="flex justify-between item-center">
                    <a href="/file/<%= val.substring(0,val.length-4) %>" class="text-blue-400">Read more</a>
                    <a href="/edit/<%= val.substring(0,val.length-4) %>" class="text-blue-400">Edit</a>
                  </div>
                </div>
              <% }) %>
            <% } else { %>
              <h3 class="ml-5 mt-11 text-gray-400">No tasks yet.</h3>
            <% } %>
          </div>
          
    </div>
</body>

</html>